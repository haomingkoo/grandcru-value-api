# Wine Intelligence API — Environment Variables
# Copy to .env and fill in your keys. Never commit .env!

# Gemini API key for LLM-powered wine matching (Gemini 2.0 Flash)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Search APIs for Vivino URL resolution (optional — LLM resolver is preferred)
BRAVE_API_KEY=YOUR_BRAVE_API_KEY_HERE
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY_HERE
GOOGLE_CSE_ID=YOUR_GOOGLE_CSE_ID_HERE
SERPER_API_KEY=YOUR_SERPER_API_KEY_HERE

# Ops endpoints (optional)
OPS_API_KEY=YOUR_OPS_KEY_HERE
# OPS_BASE_URL=https://wine.kooexperience.com
# OPS_DEFAULT_HEALTH_URL=https://web-production-f2effe.up.railway.app/health

# Database (defaults to SQLite if not set)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Frontend origins allowed to call the API (comma-separated exact origins).
# Include scheme and host, and include the port for local dev.
# Example: https://kooexperience.com and https://wine.kooexperience.com are different origins.
# CORS_ORIGINS=https://kooexperience.com,https://www.kooexperience.com,https://wine.kooexperience.com,http://127.0.0.1:5500

# Freshness and retention
# INGESTION_STALE_HOURS=24
# HISTORY_RETENTION_DAYS=90

# Public API guardrails
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_REQUESTS_PER_MINUTE=120

# Logging
# LOG_LEVEL=INFO
# ACCESS_LOG_ENABLED=true
